rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && 
        request.resource.data.keys().hasAll(['favorites', 'settings']) &&
        request.resource.data.favorites.songs is list &&
        request.resource.data.favorites.verses is list &&
        request.resource.data.settings.fontSize is number &&
        request.resource.data.settings.theme in ['light', 'dark'];
      allow update: if isOwner(userId) &&
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['favorites', 'settings']));
    }

    // Songs collection (Public read, Private write)
    match /songs/{songId} {
      allow read: if true;
      allow write: if false; // Only admin via console/internal tools for now as per prompt "admin approval"
    }

    // Devotions collection (Public read)
    match /devotions/{devotionId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
